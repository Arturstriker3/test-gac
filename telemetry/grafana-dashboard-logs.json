{
  "id": null,
  "uid": "gac-logs",
  "title": "GAC API - Saúde e Performance",
  "tags": ["gac", "logs", "load-test"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "5s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Ritmo atual (requisições/segundo)",
      "description": "Quantas requisições a API atende por segundo neste momento.",
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 0 },
      "datasource": "Loki",
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate({container=\"gac_api\"} |= \"\\\"event.dataset\\\":\\\"gac.http\\\"\" [1m]))"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Taxa de erro (%)",
      "description": "Percentual de requisições com falha. Quanto menor, melhor.",
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 0 },
      "datasource": "Loki",
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(rate({container=\"gac_api\"} |= \"\\\"event.dataset\\\":\\\"gac.http\\\"\" | json | http_success=\"false\" [1m])) / sum(rate({container=\"gac_api\"} |= \"\\\"event.dataset\\\":\\\"gac.http\\\"\" [1m]))"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Erros por minuto",
      "description": "Quantidade de falhas por minuto.",
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 0 },
      "datasource": "Loki",
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({container=\"gac_api\"} |= \"\\\"event.dataset\\\":\\\"gac.http\\\"\" | json | http_success=\"false\" [1m]))"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Tempo médio de resposta (ms)",
      "description": "Tempo médio que cada requisição leva para responder.",
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 0 },
      "datasource": "Loki",
      "targets": [
        {
          "refId": "A",
          "expr": "avg(avg_over_time({container=\"gac_api\"} |= \"\\\"event.dataset\\\":\\\"gac.http\\\"\" | json | unwrap http_duration_ms [5m]))"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Latência p50 (ms)",
      "description": "Metade das respostas ficam abaixo deste tempo.",
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 0 },
      "datasource": "Loki",
      "targets": [
        {
          "refId": "A",
          "expr": "quantile_over_time(0.50, {container=\"gac_api\"} |= \"\\\"event.dataset\\\":\\\"gac.http\\\"\" | json | unwrap http_duration_ms [5m])"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Latência p95 (ms)",
      "description": "95% das respostas ficam abaixo deste tempo.",
      "gridPos": { "h": 4, "w": 3, "x": 15, "y": 0 },
      "datasource": "Loki",
      "targets": [
        {
          "refId": "A",
          "expr": "quantile_over_time(0.95, {container=\"gac_api\"} |= \"\\\"event.dataset\\\":\\\"gac.http\\\"\" | json | unwrap http_duration_ms [5m])"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Latência p99 (ms)",
      "description": "99% das respostas ficam abaixo deste tempo.",
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 0 },
      "datasource": "Loki",
      "targets": [
        {
          "refId": "A",
          "expr": "quantile_over_time(0.99, {container=\"gac_api\"} |= \"\\\"event.dataset\\\":\\\"gac.http\\\"\" | json | unwrap http_duration_ms [5m])"
        }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Taxa de sucesso (%)",
      "description": "Percentual de requisições concluídas sem erro.",
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 0 },
      "datasource": "Loki",
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(rate({container=\"gac_api\"} |= \"\\\"event.dataset\\\":\\\"gac.http\\\"\" | json | http_success=\"true\" [1m])) / sum(rate({container=\"gac_api\"} |= \"\\\"event.dataset\\\":\\\"gac.http\\\"\" [1m]))"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "RPS (requisições por segundo)",
      "description": "Ritmo de atendimento da API ao longo do tempo.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "datasource": "Loki",
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate({container=\"gac_api\"} |= \"\\\"event.dataset\\\":\\\"gac.http\\\"\" [1m]))",
          "legendFormat": "RPS"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Volume de requisições por minuto",
      "description": "Quantidade de requisições processadas por minuto.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "datasource": "Loki",
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({container=\"gac_api\"} |= \"\\\"event.dataset\\\":\\\"gac.http\\\"\" [1m]))",
          "legendFormat": "Requests/min"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Latência ao longo do tempo (p50, p95, p99)",
      "description": "Mostra estabilidade do tempo de resposta durante o teste.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": "Loki",
      "targets": [
        {
          "refId": "A",
          "expr": "quantile_over_time(0.50, {container=\"gac_api\"} |= \"\\\"event.dataset\\\":\\\"gac.http\\\"\" | json | unwrap http_duration_ms [5m])",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "quantile_over_time(0.95, {container=\"gac_api\"} |= \"\\\"event.dataset\\\":\\\"gac.http\\\"\" | json | unwrap http_duration_ms [5m])",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "quantile_over_time(0.99, {container=\"gac_api\"} |= \"\\\"event.dataset\\\":\\\"gac.http\\\"\" | json | unwrap http_duration_ms [5m])",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Sucesso vs erro por segundo",
      "description": "Compara operações bem-sucedidas com operações que falharam.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": "Loki",
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate({container=\"gac_api\"} |= \"\\\"event.dataset\\\":\\\"gac.http\\\"\" | json | http_success=\"true\" [1m]))",
          "legendFormat": "Sucesso/s"
        },
        {
          "refId": "B",
          "expr": "sum(rate({container=\"gac_api\"} |= \"\\\"event.dataset\\\":\\\"gac.http\\\"\" | json | http_success=\"false\" [1m]))",
          "legendFormat": "Erro/s"
        }
      ]
    },
    {
      "id": 13,
      "type": "barchart",
      "title": "Performance por endpoint - quantidade",
      "description": "Mostra quais rotas recebem mais requisições por minuto.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": "Loki",
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (http_route) (count_over_time({container=\"gac_api\"} |= \"\\\"event.dataset\\\":\\\"gac.http\\\"\" | json [5m]))",
          "legendFormat": "{{http_route}}"
        }
      ]
    },
    {
      "id": 14,
      "type": "barchart",
      "title": "Performance por endpoint - tempo médio (ms)",
      "description": "Compara o tempo médio de resposta entre as rotas.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": "Loki",
      "targets": [
        {
          "refId": "A",
          "expr": "avg by (http_route) (avg_over_time({container=\"gac_api\"} |= \"\\\"event.dataset\\\":\\\"gac.http\\\"\" | json | unwrap http_duration_ms [5m]))",
          "legendFormat": "{{http_route}}"
        }
      ]
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Requisições lentas por minuto",
      "description": "Contagem de respostas lentas (acima de 300ms).",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 36 },
      "datasource": "Loki",
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({container=\"gac_api\"} |= \"\\\"event.dataset\\\":\\\"gac.http\\\"\" | json | http_slow=\"true\" [1m]))",
          "legendFormat": "Lentas/min"
        }
      ]
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Uso de CPU da API (%)",
      "description": "Quanto da CPU do processo da API está sendo usado.",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 36 },
      "datasource": "Loki",
      "targets": [
        {
          "refId": "A",
          "expr": "clamp_max(sum by () (avg_over_time({container=\"gac_api\"} |= \"\\\"event.dataset\\\":\\\"gac.runtime\\\"\" | json | unwrap runtime_cpu_usage_percent [1m])), 100)",
          "legendFormat": "CPU %"
        }
      ]
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "Event loop lag (ms)",
      "description": "Atraso interno da aplicação para processar tarefas. Quanto menor, melhor.",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 36 },
      "datasource": "Loki",
      "targets": [
        {
          "refId": "A",
          "expr": "sum by () (avg_over_time({container=\"gac_api\"} |= \"\\\"event.dataset\\\":\\\"gac.runtime\\\"\" | json | unwrap runtime_event_loop_lag_ms [1m]))",
          "legendFormat": "Lag (ms)"
        }
      ]
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "Uso de memória da API (MB)",
      "description": "Memória consumida pela API ao longo do teste.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 42 },
      "datasource": "Loki",
      "targets": [
        {
          "refId": "A",
          "expr": "sum by () (avg_over_time({container=\"gac_api\"} |= \"\\\"event.dataset\\\":\\\"gac.runtime\\\"\" | json | unwrap runtime_memory_rss_mb [1m]))",
          "legendFormat": "RSS (MB)"
        },
        {
          "refId": "B",
          "expr": "sum by () (avg_over_time({container=\"gac_api\"} |= \"\\\"event.dataset\\\":\\\"gac.runtime\\\"\" | json | unwrap runtime_memory_heap_used_mb [1m]))",
          "legendFormat": "Heap usado (MB)"
        }
      ]
    },
    {
      "id": 19,
      "type": "timeseries",
      "title": "Métricas de negócio (criações por minuto)",
      "description": "Mostra o ritmo de criação de usuários e grupos.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 50 },
      "datasource": "Loki",
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({container=\"gac_api\"} |= \"user node created\" [1m]))",
          "legendFormat": "Usuários criados/min"
        },
        {
          "refId": "B",
          "expr": "sum(count_over_time({container=\"gac_api\"} |= \"group node created\" [1m]))",
          "legendFormat": "Grupos criados/min"
        }
      ]
    },
    {
      "id": 20,
      "type": "barchart",
      "title": "Erros por endpoint (últimos 5 min)",
      "description": "Ajuda a identificar qual rota gera mais erro.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 50 },
      "datasource": "Loki",
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (http_route) (count_over_time({container=\"gac_api\"} |= \"\\\"event.dataset\\\":\\\"gac.http\\\"\" | json | http_success=\"false\" [5m]))",
          "legendFormat": "{{http_route}}"
        }
      ]
    },
    {
      "id": 21,
      "type": "logs",
      "title": "Logs da API",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 58 },
      "datasource": "Loki",
      "targets": [{ "refId": "A", "expr": "{container=\"gac_api\"}" }]
    },
    {
      "id": 22,
      "type": "logs",
      "title": "Apenas erros",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 66 },
      "datasource": "Loki",
      "targets": [
        {
          "refId": "A",
          "expr": "{container=\"gac_api\"} |= \"\\\"log.level\\\":\\\"error\\\"\""
        }
      ]
    }
  ]
}
